# Copy to .env.local and fill in for dev. Loaded by bin/dev.
#
# .env.local is gitignored — credentials never reach the repo.
# In production, depot's aviary/configure.sh sets the same variables
# in the container's env, so app code reads them identically in
# both environments.

# Jellyfin base URL. From your Mac on the tailnet, use the
# tailscale HTTPS URL. Same shape as what configure.sh's summary
# prints under "Jellyfin:".
JELLYFIN_URL=https://framework-depot.<tailnet>.ts.net:8096

# Jellyfin API key. Get one at:
#   Jellyfin admin dashboard → API Keys → "+" → name it "aviary"
# Reuse the existing "sonarr" key only if you don't want a separate
# audit trail per integration.
JELLYFIN_API_KEY=paste-the-key-here

# Jellyseerr — powers the release-calendar widget on show detail
# pages (next-episode air dates via TMDB sync). Optional; if unset,
# the trailer treatment shows for every show. Same tailnet HTTPS
# pattern as Jellyfin above. API key from Jellyseerr settings →
# General → "API Key".
JELLYSEERR_URL=https://framework-depot.<tailnet>.ts.net:5055
JELLYSEERR_API_KEY=paste-the-key-here
