<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <%!--
      iOS home-screen bookmark behavior. apple-mobile-web-app-capable
      makes the page run fullscreen (no Safari chrome) when launched
      from the home screen; the title shows under the icon. theme-color
      switches with system appearance so the iOS status bar tints to
      match day/night automatically.
    --%>
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={AviaryWeb.Layouts.home_screen_title()} />
    <%!--
      Two icons on purpose. apple-touch-icon (180px, with the oxblood
      rule) is the iOS home-screen / PWA icon, where there's room for
      the full mark. favicon.ico carries a rule-less PTV at 16/32/48 —
      the rule can't survive a downscale to a browser tab, so the small
      sizes drop it and letterspace the letters instead.
    --%>
    <link rel="apple-touch-icon" href={~p"/images/apple-touch-icon.png"} />
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#F2F0E7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1B1B26" media="(prefers-color-scheme: dark)" />

    <%!--
      Link-unfurl preview + search snippet. iMessage, Slack, etc. read
      Open Graph tags to render the rich card when someone shares the
      link; that fetch is unauthenticated, so these must live in the
      global layout (they render on the login page too, which is what
      a family member's shared link lands on). og:image must be an
      ABSOLUTE url — Layouts.og_image_url/0 builds one from the
      configured host. twitter:card upgrades the preview to the
      large-image format on clients that read the twitter: namespace.
      All values come from the same brand config as the tab title.
    --%>
    <meta name="description" content={AviaryWeb.Layouts.site_description()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={AviaryWeb.Layouts.tab_title()} />
    <meta property="og:title" content={AviaryWeb.Layouts.tab_title()} />
    <meta property="og:description" content={AviaryWeb.Layouts.site_description()} />
    <meta property="og:url" content={AviaryWeb.Endpoint.url()} />
    <meta property="og:image" content={AviaryWeb.Layouts.og_image_url()} />
    <meta property="og:image:alt" content={AviaryWeb.Layouts.tab_title()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={AviaryWeb.Layouts.tab_title()} />
    <meta name="twitter:description" content={AviaryWeb.Layouts.site_description()} />
    <meta name="twitter:image" content={AviaryWeb.Layouts.og_image_url()} />
    <%!--
      Tab title brand — defaults to "Aviary" but reads TAB_TITLE env
      at runtime (set in depot's aviary.rb compose env). Per-LiveView
      `page_title` only sets the page-specific part (e.g. "Settings");
      the brand suffix is appended here.
    --%>
    <.live_title
      default={AviaryWeb.Layouts.tab_title()}
      suffix={" · " <> AviaryWeb.Layouts.tab_title()}
      phx-no-format
    >{assigns[:page_title]}</.live_title>

    <%!--
      Google Fonts — Fraunces (variable, with SOFT + WONK axes for
      character on display text) for headlines + the wordmark;
      Instrument Sans for everything else. preconnect early so the
      first paint isn't fighting font latency.
    --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <%!--
      Warm the TMDB image CDN connection — Discover renders dozens of
      posters/backdrops served from image.tmdb.org, and without this
      every fresh visit pays DNS + TLS handshake before the first
      image starts streaming. /image/tmdb/* proxy aside, even when
      the user hits the unproxied URL (a stray reference, or first
      load before the proxy populates) this knocks ~100-300ms off.
    --%>
    <link rel="preconnect" href="https://image.tmdb.org" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Newsreader:opsz,wght@6..72,300..700&display=swap"
    />

    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>

    <%!--
      HLS.js for non-Safari browsers. Safari plays HLS natively (and
      that path is also what gives us AirPlay support out of the box),
      but every other browser needs JS to consume HLS streams. CDN
      load defers (script doesn't block render) and is cheap to cache.
    --%>
    <script defer src="https://cdn.jsdelivr.net/npm/hls.js@1.5.17/dist/hls.min.js">
    </script>

    <%!--
      Theme bootstrap: read the persisted choice from localStorage and
      set data-theme on <html> before paint to avoid a flash of the
      wrong palette. Default is "night" — aviary is a couch-evening
      media app, not a daylight productivity tool, and the editorial-
      minimalist palette reads stronger on the deep-ink background.
      Existing users with a saved preference keep it; only first
      visitors get the dark default. Also listens for storage events
      (so a theme change in one tab propagates to others) and for
      phx:set-theme (dispatched by the toggle button).
    --%>
    <script>
      (() => {
        const setTheme = (theme) => {
          localStorage.setItem("aviary:theme", theme);
          document.documentElement.setAttribute("data-theme", theme);
        };
        setTheme(localStorage.getItem("aviary:theme") || "night");
        window.addEventListener("storage", (e) => e.key === "aviary:theme" && setTheme(e.newValue || "night"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.theme));
        window.addEventListener("phx:toggle-theme", () => {
          const current = document.documentElement.getAttribute("data-theme") || "night";
          setTheme(current === "day" ? "night" : "day");
        });
      })();
    </script>

    <%!--
      iOS install gate. Family members are on iPhones; if they hit the
      login screen via a normal Safari tab (not from the home-screen
      icon), we want them in the full PWA, not a browser tab. So the
      login template renders TWO panels — one with the form and one
      with install instructions — and this script sets a data
      attribute on <html> synchronously so the right one shows before
      paint. iOS Safari + not standalone → install prompt; everything
      else (desktop, Android, or already-installed PWA) → form.
    --%>
    <script>
      (() => {
        const ua = navigator.userAgent || "";
        const isIOS = /iPhone|iPad|iPod/.test(ua) && !window.MSStream;
        const isStandalone =
          window.matchMedia("(display-mode: standalone)").matches ||
          window.navigator.standalone === true;
        const forceInstall = new URLSearchParams(window.location.search).has("install");
        if ((isIOS && !isStandalone) || forceInstall) {
          document.documentElement.setAttribute("data-needs-install", "true");
        }
      })();
    </script>

    <style>
      /* Settings page: reveal the install section only when iOS
         Safari + not standalone (the same gate as the one-time
         install hint flash). Hidden everywhere else so desktop
         users + installed-PWA users don't see "install" copy that
         doesn't apply to them. */
      html[data-needs-install="true"] .pwa-install-section { display: block !important; }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
